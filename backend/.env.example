PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/printsmart?schema=public
JWT_SECRET=supersecretjwtkeychangeinproduction

# AWS S3 Settings (Optional - fallback to local storage if not provided)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# Fallback Local Storage settings
UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:3000
