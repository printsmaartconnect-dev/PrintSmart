datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PRINTING
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  PRINTING
  DONE
}

enum PrintType {
  BW
  COLOR
}

enum PaperSize {
  A4
  A3
  A5
  LEGAL
  LETTER
  EXECUTIVE
  LEDGER
  TABLOID
}

enum PrintQuality {
  DRAFT
  NORMAL
  HIGH
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
}

enum PrintSide {
  SINGLE
  DOUBLE
}

enum Language {
  ENGLISH
  HINDI
  MARATHI
  GUJARATI
  OTHER
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  name     String?
  phone    String?
  language Language @default(ENGLISH)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders   Order[]
  feedback Feedback[]

  @@index([email])
}

model Shopkeeper {
  id               String  @id @default(uuid())
  email            String  @unique
  password         String
  phone            String
  shopkeeperIdCode String? @unique

  shopName     String
  ownerName    String?
  shopSlug     String  @unique
  address      String?
  category     String? @default("Printing & Photocopy")
  subCategory  String? @default("Xerox & Digital Prints")
  languagePref String? @default("English")
  gstNumber    String?
  socials      Json?
  pricing      Json?
  logoUrl      String?

  // QR Code
  qrCode        String?   @unique
  qrCodeUrl     String?
  qrValue       String?
  qrGeneratedAt DateTime?

  // Statistics
  totalOrders       Int   @default(0)
  totalEarnings     Float @default(0.0)
  activeSubscribers Int   @default(0)

  orders     Order[]
  statistics ShopkeeperStatistics?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([shopSlug])
}

model Order {
  id      String @id @default(uuid())
  orderId String @unique // Format: 0526PBW/C01

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  shopkeeperId String
  shopkeeper   Shopkeeper @relation(fields: [shopkeeperId], references: [id], onDelete: Cascade)

  customerName String  @default("Anonymous")
  phone        String?

  printConfiguration PrintConfiguration?
  orderFiles         OrderFile[]
  queue              Queue?
  invoice            Invoice?

  price       Float @default(0)
  subtotal    Float @default(0)
  tax         Float @default(0)
  discount    Float @default(0)
  totalAmount Float @default(0)

  status OrderStatus @default(PENDING)

  estimatedTime Int @default(5) // in minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopkeeperId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderFile {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  originalFileName String
  customFileName   String?
  fileUrl          String
  thumbnailUrl     String?
  fileSize         Int

  createdAt DateTime @default(now())

  @@index([orderId])
}

model PrintConfiguration {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  printType   PrintType    @default(BW)
  copies      Int          @default(1)
  paperSize   PaperSize    @default(A4)
  sides       PrintSide    @default(SINGLE)
  orientation Orientation  @default(PORTRAIT)
  quality     PrintQuality @default(NORMAL)
  pageRange   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Queue {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  position          Int
  status            QueueStatus @default(WAITING)
  estimatedWaitTime Int         @default(5) // in minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([position])
}

model Invoice {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  invoiceNumber String  @unique
  pdfUrl        String?

  subtotal    Float
  tax         Float
  discount    Float
  totalAmount Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceNumber])
}

model Feedback {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject       String
  message       String
  rating        Int? // 1-5 stars
  attachmentUrl String?

  status String @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model ShopkeeperStatistics {
  id String @id @default(uuid())

  shopkeeperId String     @unique
  shopkeeper   Shopkeeper @relation(fields: [shopkeeperId], references: [id], onDelete: Cascade)

  // Daily stats
  todayOrders      Int   @default(0)
  todayEarnings    Float @default(0)
  todayBWPrints    Int   @default(0)
  todayColorPrints Int   @default(0)

  // Weekly stats
  weeklyGrowth Float @default(0)

  // Monthly stats
  monthlyRevenue        Float  @default(0)
  topPaperSize          String @default("A4")
  printTypeDistribution Json? // { BW: 0, COLOR: 0 }

  // Overall
  totalOrders   Int   @default(0)
  totalCopies   Int   @default(0)
  totalEarnings Float @default(0)
  avgOrderValue Float @default(0)

  lastUpdated DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopkeeperId])
}
